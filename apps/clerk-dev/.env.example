# Same Clerk Application as repo root `.env`: CLERK_PUBLISHABLE_KEY
# Keys are safe in the browser — do not paste the secret key here.
VITE_CLERK_PUBLISHABLE_KEY=

# UUID for X-Organization-Id header + medications.organization_id in SQL seeds.
